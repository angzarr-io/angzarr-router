/target
mutants.out*

# devcontainer cargo registry cache (bind-mounted)
/.devcontainer/cargo-cache/

# container-overlay cargo home (host-delegation runs)
/.cargo-container/

# ctxloom private working state (synced bundles, session/context, project id)
*.ctxloom.bak
.agents/
.codex/config.toml

# ctxloom private working state (synced bundles, session/context, project id)
.ctxloom/ephemeral/
.ctxloom/project-id
.ctxloom/cache/

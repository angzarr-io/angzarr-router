{
  "mcpServers": {
    "ctxloom": {
      "_ctxloom": "ctxloom-auto",
      "args": [
        "mcp"
      ],
      "command": "ctxloom",
      "cwd": "${CLAUDE_PROJECT_DIR}"
    },
    "sequential-thinking": {
      "_ctxloom": "bundle:https://github.com/ctxloom/ctxloom-default@bundles/sequential-thinking",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    },
    "taskloom": {
      "_ctxloom": "bundle:builtin:taskloom",
      "args": [
        "mcp"
      ],
      "command": "taskloom"
    }
  }
}

{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2023"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@angzarr/router": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "conformance/**/*.ts", "gen/**/*.ts"]
}

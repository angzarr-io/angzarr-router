<Project Sdk="Microsoft.NET.Sdk">
  <!-- The C# binding for the angzarr router. Loads the shared router-ffi cdylib
       in-process via P/Invoke (the path comes from ANGZARR_ROUTER_LIB, resolved
       by a NativeLibrary.SetDllImportResolver in Ffi.cs). Protobuf message types
       + the angzarr dispatch wiring are generated by `just csharp-binding-gen`
       (buf) into gen/ and are never committed. -->

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <!-- unsafe: the FFI trampoline is an [UnmanagedCallersOnly] method whose
         signature uses raw byte*/AngzarrBuf* pointers. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <RootNamespace>Angzarr.Router</RootNamespace>
    <AssemblyName>Angzarr.Router</AssemblyName>
    <!-- Explicit compile items below: the project dir also holds conformance/,
         which is a separate test project. -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- Google.Protobuf provides the well-known types (Any, …);
         Google.Api.CommonProtos provides google.rpc.Status / ErrorInfo — both
         excluded from codegen and consumed from these runtime packages (the
         protobuf-java + proto-google-common-protos analog). -->
    <PackageReference Include="Google.Protobuf" Version="3.28.3" />
    <PackageReference Include="Google.Api.CommonProtos" Version="2.15.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="src/**/*.cs" />
    <!-- Generated protobuf + angzarr wiring (produced by buf before build). -->
    <Compile Include="gen/**/*.cs" />
  </ItemGroup>
</Project>
